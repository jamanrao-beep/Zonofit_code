// ZonoFit — Prisma Schema
// PostgreSQL + PostGIS
// Run: npx prisma migrate dev --name init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis]
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum SystemRole {
  MEMBER
  GYM_OWNER
  ADMIN
}

enum MembershipStatus {
  ACTIVE
  PAST_DUE
  FROZEN
  CANCELLED
  NO_SHOW
  PENDING
  EXPIRED
}

enum MembershipTier {
  BASIC
  STANDARD
  PREMIUM
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum CheckInMethod {
  QR
  OTP
  STAFF_APPROVAL
  TIME_CODE
}

enum CheckInStatus {
  PENDING
  VERIFIED
  FAILED
  EXPIRED
}

enum CreditTransactionType {
  MEMBERSHIP_GRANT    // Credits given when membership starts/renews
  VISIT_SPEND         // Credits spent on a gym visit booking
  PURCHASE            // User bought additional credits
  BONUS               // Achievement/referral/reward credits
  CONVERSION          // Credits converted to INR cash
  RECONVERSION        // Cash converted back to credits
  EXPIRY              // Credits expired after membership ended
  REFUND              // Credits refunded on booking cancellation
}

enum GymCategory {
  STANDARD
  PREMIUM
  BEGINNER_FRIENDLY
  CROSSFIT
  BOUTIQUE
}

enum RoleType {
  TRAINER
  BUDDY
}

// ─────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  phone     String?
  avatarUrl String?
  expoPushToken String?

  // Portal Authentication
  systemRole  SystemRole @default(MEMBER)
  passwordHash String?
  isSuspended Boolean    @default(false)

  // Referral system (Phase 2 — column exists but logic is Phase 2)
  referralCode       String?  @unique
  referredByUserId   String?
  referredBy         User?    @relation("Referrals", fields: [referredByUserId], references: [id])
  referredUsers      User[]   @relation("Referrals")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Journey & Habit Progress
  streak        Int    @default(0)
  totalWorkouts Int    @default(0)
  trainingHours Int    @default(0)
  identityStage String @default("Beginner")

  // Relations
  membership         Membership?
  wallet             CreditWallet?
  bookings           Booking[]
  creditTransactions CreditTransaction[]
  marketplaceOrders  MarketplaceOrder[]
  chatMessages       ChatMessage[]
  userBadges         UserBadge[]
  userChallenges     UserChallenge[]
  roleProfile        UserRoleProfile?
  featureFeedbacks   FeatureFeedback[]
  paymentOrders      PaymentOrder[]
  notifications      Notification[]
  gymsOwned          Gym[]             @relation("GymOwner")

  adminProfile       AdminProfile?
  auditLogs          AdminAuditLog[]
  supportTickets     SupportTicket[]   @relation("UserSupportTickets")
  assignedTickets    SupportTicket[]   @relation("AssignedSupportTickets")
  trialGymVotes      TrialGymVote[]
  @@map("users")
}

model PaymentOrder {
  id              String   @id @default(uuid())
  userId          String
  razorpayOrderId String   @unique
  amountPaise     Int
  creditsToAdd    Int
  cashToAddPaise  Int      @default(0)
  status          String   @default("CREATED") // CREATED, PAID, FAILED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("payment_orders")
}

// ─────────────────────────────────────────────
// MEMBERSHIP
// ─────────────────────────────────────────────

model MembershipPlan {
  id             String         @id @default(uuid())
  name           String         @unique
  tier           MembershipTier
  monthlyCredits Int            // Credits granted on activation/renewal
  priceInPaise   Int            // Price in Indian paise (₹1 = 100 paise) — store integers, never floats for money
  durationDays   Int            @default(30)
  features       String[]       // Display-only feature list for the plan card
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  memberships    Membership[]

  @@map("membership_plans")
}

model Membership {
  id        String           @id @default(uuid())
  userId    String           @unique
  planId    String
  status    MembershipStatus @default(PENDING)
  startDate DateTime
  endDate   DateTime         // Expiry — credits expire 15 days after this
  autoRenew Boolean          @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan MembershipPlan @relation(fields: [planId], references: [id])
  
  primaryGymId      String?
  primaryGymVisits  Int      @default(0)
  primaryGym        Gym?     @relation("PrimaryGym", fields: [primaryGymId], references: [id])

  @@map("memberships")
}

// ─────────────────────────────────────────────
// CREDIT WALLET & TRANSACTIONS
// ─────────────────────────────────────────────

model CreditWallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  balance   Int      @default(0) // In credits. 1 credit = ₹10 fitness value
  // Cash balance from credit conversions (in paise)
  convertibleCashBalanceInPaise Int @default(0)
  // Cash balance from direct top-ups (in paise)
  nonConvertibleCashBalanceInPaise Int @default(0)
  cashExpiryDate     DateTime? // Date when convertible cash balance will expire and be zeroed
  updatedAt DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions CreditTransaction[]

  @@map("credit_wallets")
}

model CreditTransaction {
  id          String                @id @default(uuid())
  userId      String
  walletId    String
  type        CreditTransactionType
  // Positive = credit added, Negative = credit deducted
  // Using Int not Float — credits are always whole numbers
  amount      Int
  balanceAfter Int                  // Snapshot of wallet balance after this transaction
  description String
  bookingId   String?               // Linked booking if this was a VISIT_SPEND or REFUND
  referenceId String?               // Payment gateway reference ID for PURCHASE type
  createdAt   DateTime              @default(now())

  user    User         @relation(fields: [userId], references: [id])
  wallet  CreditWallet @relation(fields: [walletId], references: [id])
  booking Booking?     @relation(fields: [bookingId], references: [id])

  @@index([userId])
  @@index([walletId])
  @@map("credit_transactions")
}

// ─────────────────────────────────────────────
// GYM
// ─────────────────────────────────────────────

model Gym {
  id          String      @id @default(uuid())
  name        String
  description String?
  address     String
  city        String
  pincode     String?
  state       String      @default("Maharashtra")

  // Lat/Lng stored as plain floats for display + fallback
  lat         Float
  lng         Float
  // PostGIS geometry column for spatial queries (ST_DWithin, ST_Distance)
  // Managed via raw SQL in migrations — Prisma uses Unsupported for this type
  // Insert/update via: ST_SetSRID(ST_MakePoint(lng, lat), 4326)
  location    Unsupported("geometry(Point, 4326)")?

  creditCost    Int         // Credits required per visit — ZonoFit retains final say
  isVerified    Boolean     @default(false)
  isActive      Boolean     @default(true)
  category      GymCategory @default(STANDARD)
  facilities    String[]    // e.g. ["Strength", "Cardio", "CrossFit", "Steam Room"]
  imageUrls     String[]
  rating        Float       @default(0.0)
  totalRatings  Int         @default(0)
  openingTime   String      @default("06:00") // HH:MM
  closingTime   String      @default("22:00") // HH:MM
  totalSlots    Int         @default(20)      // Slots per day
  contactPhone  String?
  contactEmail  String?

  ownerId       String?
  owner         User?       @relation("GymOwner", fields: [ownerId], references: [id])

  partnerSince  DateTime?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  bookings          Booking[]
  chatMessages      ChatMessage[]
  userRoles         UserRoleGym[]
  primaryMemberships Membership[] @relation("PrimaryGym")
  payouts           GymPayout[]
  offers            GymOffer[]
  applications      GymApplication[]
  supportTickets    SupportTicket[]

  // Economy Overrides (fallback to global settings if null)
  creditPurchasePrice   Int?
  creditConversionValue Int?
  initialVisitCut       Int?
  cashExpiryDays        Int?
  
  plans                 GymPlan[]

  @@index([city])
  @@index([isActive])
  @@map("gyms")
}

model GymPlan {
  id                   String @id @default(uuid())
  gymId                String
  name                 String
  description          String?
  
  initialPeriodMonths  Int
  initialCutoffDays    Int
  subsequentCutoffDays Int
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  gym Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)
  
  @@map("gym_plans")
}

// ─────────────────────────────────────────────
// BOOKING
// ─────────────────────────────────────────────

model Booking {
  id              String        @id @default(uuid())
  userId          String
  gymId           String
  visitDate       DateTime      // Date of the visit (date only, time comes from timeSlot)
  timeSlot        String        // e.g. "07:00-08:00"
  status          BookingStatus @default(PENDING)
  creditsDeducted Int           // Credits locked at booking time — used for refund calc

  // QR pass code generated at booking — displayed in app for gym staff to scan
  passCode        String        @unique @default(uuid())

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user               User                @relation(fields: [userId], references: [id])
  gym                Gym                 @relation(fields: [gymId], references: [id])
  checkIn            CheckIn?
  creditTransactions CreditTransaction[]

  @@index([userId])
  @@index([gymId])
  @@index([visitDate])
  @@index([status])
  @@map("bookings")
}

// ─────────────────────────────────────────────
// CHECK-IN
// ─────────────────────────────────────────────

model CheckIn {
  id               String        @id @default(uuid())
  bookingId        String        @unique
  method           CheckInMethod
  verificationCode String        // QR data / OTP / time code — hashed in prod
  status           CheckInStatus @default(PENDING)
  attemptCount     Int           @default(0)
  verifiedAt       DateTime?     // Set by backend on successful verification
  verifiedByStaff  String?       // Staff identifier if method = STAFF_APPROVAL
  expiresAt        DateTime      // Code expiry — short-lived for security
  createdAt        DateTime      @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("check_ins")
}

// ─────────────────────────────────────────────
// MARKETPLACE
// ─────────────────────────────────────────────

model MarketplaceItem {
  id          String   @id @default(uuid())
  title       String
  description String
  pricePaise  Int      // Price in INR paise
  imageUrl    String
  inStock     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders      MarketplaceOrder[]

  @@map("marketplace_items")
}

model MarketplaceOrder {
  id          String   @id @default(uuid())
  userId      String
  itemId      String
  quantity    Int      @default(1)
  totalPaise  Int
  status      String   @default("COMPLETED")
  createdAt   DateTime @default(now())

  user        User            @relation(fields: [userId], references: [id])
  item        MarketplaceItem @relation(fields: [itemId], references: [id])

  @@map("marketplace_orders")
}

// ─────────────────────────────────────────────
// CHAT
// ─────────────────────────────────────────────

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String
  gymId     String
  sender    String   // "USER" or "GYM"
  text      String
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id])
  gym       Gym  @relation(fields: [gymId], references: [id])

  @@index([userId, gymId])
  @@map("chat_messages")
}

// ─────────────────────────────────────────────
// QUOTE
// ─────────────────────────────────────────────

model Quote {
  id        String   @id @default(uuid())
  text      String
  author    String?
  createdAt DateTime @default(now())

  @@map("quotes")
}

// ─────────────────────────────────────────────
// BADGES & MILESTONES (JOURNEY)
// ─────────────────────────────────────────────

model Badge {
  id          String   @id @default(uuid())
  name        String
  emoji       String
  description String
  requirement String
  unlockedAt  Int?     // Threshold
  isSpecial   Boolean  @default(false)
  createdAt   DateTime @default(now())
  
  userBadges  UserBadge[]

  @@map("badges")
}

model UserBadge {
  id        String   @id @default(uuid())
  userId    String
  badgeId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Milestone {
  id          String   @id @default(uuid())
  title       String
  description String
  emoji       String
  targetCount Int
  rewardCredits Int
  createdAt   DateTime @default(now())

  @@map("milestones")
}

// ─────────────────────────────────────────────
// CHALLENGES
// ─────────────────────────────────────────────

model Challenge {
  id            String   @id @default(uuid())
  title         String
  description   String
  emoji         String
  targetCount   Int
  rewardCredits Int
  deadline      DateTime?
  type          String   // "visits" | "streak" | "gyms"
  createdAt     DateTime @default(now())

  userChallenges UserChallenge[]

  @@map("challenges")
}

model UserChallenge {
  id            String   @id @default(uuid())
  userId        String
  challengeId   String
  currentCount  Int      @default(0)
  completed     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge     Challenge  @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([userId, challengeId])
  @@map("user_challenges")
}

// ─────────────────────────────────────────────
// ROLES (TRAINERS & BUDDIES)
// ─────────────────────────────────────────────

model UserRoleProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  role           RoleType
  
  bio            String?
  // Trainer specific
  costPerSessionInPaise Int?     // Cost per session in cash points (paise)
  specialties           String[]
  // Buddy specific
  timingInterval String?  // e.g. "07:00 AM - 08:30 AM"
  
  isApproved     Boolean  @default(false)
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  gyms           UserRoleGym[]

  @@map("user_role_profiles")
}

model UserRoleGym {
  id                String          @id @default(uuid())
  userRoleProfileId String
  gymId             String
  
  profile           UserRoleProfile @relation(fields: [userRoleProfileId], references: [id], onDelete: Cascade)
  gym               Gym             @relation(fields: [gymId], references: [id], onDelete: Cascade)
  
  @@unique([userRoleProfileId, gymId])
  @@map("user_role_gyms")
}

// ─────────────────────────────────────────────
// FEATURE FEEDBACK (EARLY ACCESS)
// ─────────────────────────────────────────────

model FeatureFeedback {
  id          String   @id @default(uuid())
  userId      String
  featureName String   // e.g. 'ai-trainer', 'meal-scan'
  comment     String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("feature_feedback")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  isRead    Boolean  @default(false)
  type      String   @default("INFO") // INFO, WARNING, SUCCESS
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

// ─────────────────────────────────────────────
// SYSTEM SETTINGS
// ─────────────────────────────────────────────

model SystemSettings {
  id                    String   @id @default("default")
  creditPurchasePrice   Int      @default(10)  // How much 1 credit costs (₹10)
  creditConversionValue Int      @default(8)   // How much cash 1 credit yields (₹8)
  cashExpiryDays        Int      @default(15)  // Days until converted cash expires
  initialVisitCut       Int      @default(10)  // Initial visits locked to primary gym
  
  // Emergency Kill Switches
  referralsEnabled      Boolean  @default(true)
  payoutsEnabled        Boolean  @default(true)
  signupsEnabled        Boolean  @default(true)
  couponsEnabled        Boolean  @default(true)
  
  updatedAt             DateTime @updatedAt

  @@map("system_settings")
}

// ─────────────────────────────────────────────
// GYM PAYOUTS & OFFERS
// ─────────────────────────────────────────────

model GymPayout {
  id          String   @id @default(uuid())
  gymId       String
  periodStart DateTime
  periodEnd   DateTime
  amountPaise Int
  status      String   @default("PENDING") // PENDING, PAID
  payoutDate  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  gym Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([gymId])
  @@map("gym_payouts")
}

model GymOffer {
  id           String   @id @default(uuid())
  gymId        String
  title        String
  discountText String
  status       String   @default("DRAFT") // DRAFT, ACTIVE
  expiryDate   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  gym Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([gymId])
  @@map("gym_offers")
}

// ─────────────────────────────────────────────
// ADMIN FEATURES
// ─────────────────────────────────────────────

enum AdminRoleType {
  FOUNDER
  OPS_MANAGER
  SALES_REP
  SUPPORT_AGENT
  FINANCE_ADMIN
  MARKETING_MANAGER
}

model AdminProfile {
  id        String        @id @default(uuid())
  userId    String        @unique
  roleType  AdminRoleType @default(OPS_MANAGER)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

model AdminAuditLog {
  id          String   @id @default(uuid())
  adminId     String
  actionType  String   // e.g., "APPROVE_GYM", "RELEASE_PAYOUT"
  targetId    String?  // ID of the entity affected
  details     String?  // JSON string or text explaining the change
  createdAt   DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("admin_audit_logs")
}

model GymApplication {
  id            String   @id @default(uuid())
  gymId         String
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED, NEEDS_CLARIFICATION
  documentsJson String?  // Stores uploaded URLs/references
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  gym Gym @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@map("gym_applications")
}

model SupportTicket {
  id          String   @id @default(uuid())
  subject     String
  message     String
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority    String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  
  userId      String?
  gymId       String?
  assignedToId String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User?  @relation("UserSupportTickets", fields: [userId], references: [id], onDelete: Cascade)
  gym         Gym?   @relation(fields: [gymId], references: [id], onDelete: Cascade)
  assignedTo  User?  @relation("AssignedSupportTickets", fields: [assignedToId], references: [id], onDelete: SetNull)

  @@map("support_tickets")
}

model MarketingCoupon {
  id            String   @id @default(uuid())
  code          String   @unique
  discountType  String   @default("PERCENTAGE") // PERCENTAGE, FIXED_AMOUNT
  discountValue Int
  usageLimit    Int?
  usageCount    Int      @default(0)
  expiryDate    DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("marketing_coupons")
}

model SystemContent {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_content")
}

model TrialGym {
  id          String   @id @default(uuid())
  name        String
  city        String
  area        String
  description String?
  imageUrl    String?
  
  votes       TrialGymVote[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("trial_gyms")
}

model TrialGymVote {
  id          String   @id @default(uuid())
  trialGymId  String
  userId      String
  createdAt   DateTime @default(now())
  
  trialGym    TrialGym @relation(fields: [trialGymId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([trialGymId, userId])
  @@map("trial_gym_votes")
}
