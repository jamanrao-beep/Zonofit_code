# ─────────────────────────────────────────────
# ZonoFit Server — Environment Variables
# Copy this file to .env and fill in real values
# Never commit .env to version control
# ─────────────────────────────────────────────

# PostgreSQL + PostGIS connection URL
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/zonofit?schema=public"

# Clerk secret key (from Clerk dashboard → API Keys)
# Used server-side to verify JWTs from the mobile app
CLERK_SECRET_KEY="sk_test_..."

# Clerk publishable key (safe to expose in mobile app)
CLERK_PUBLISHABLE_KEY="pk_test_..."

# Clerk webhook secret (from Clerk dashboard → Webhooks)
# Used to verify incoming webhook payloads from Clerk
CLERK_WEBHOOK_SECRET="whsec_..."

# Server port
PORT=3000

# Node environment
NODE_ENV="development"

# CORS — comma-separated list of allowed origins
# For development, Expo runs on localhost:8081
ALLOWED_ORIGINS="http://localhost:8081,exp://localhost:8081"
